def _spec_header_plain() -> str:
    return (
        col("TYPE",      _W[0]) + "  " +
        col("SYSTEM-ID", _W[1]) + "  " +
        col("B-CNT", _W[2], "right") + "  " +
        col("AVG",   _W[3], "right") + " " +
        col("MAX",   _W[4], "right") + " ms  " +
        col("R-CNT", _W[5], "right") + "  " +
        col("AVG",   _W[6], "right") + " " +
        col("MAX",   _W[7], "right") + " ms  " +
        col("W",     _W[8], "right") + " " +
        col("E",     _W[9], "right")
    )


def _spec_row_plain(spec: dict) -> str:
    sid   = spec.get("systemID", "")
    typ   = spec.get("type", "")
    build = spec.get("build", {})
    rend  = spec.get("render", {})
    diag  = spec.get("diag", {})
    dw = sum(diag.get(p, {}).get("warn",  0) for p in ("parse", "build", "render"))
    de = sum(diag.get(p, {}).get("error", 0) for p in ("parse", "build", "render"))
    return (
        col(typ, _W[0]) + "  " +
        col(sid, _W[1]) + "  " +
        col(build.get("count", 0),         _W[2], "right") + "  " +
        col(ms_str(build.get("avgMs")),    _W[3], "right") + " " +
        col(ms_str(build.get("maxMs")),    _W[4], "right") + "     " +
        col(rend.get("count", 0),          _W[5], "right") + "  " +
        col(ms_str(rend.get("avgMs")),     _W[6], "right") + " " +
        col(ms_str(rend.get("maxMs")),     _W[7], "right") + "     " +
        col(dw,                            _W[8], "right") + " " +
        col(de,                            _W[9], "right")
    )


def _format_spec_detail_lines(data: dict) -> list:
    lines = []
    lines.append(f"SYSTEM-ID : {data.get('systemID', '')}")
    lines.append(f"TYPE      : {data.get('type', '')}")
    lines.append("")
    for section in ("build", "render"):
        s        = data.get(section, {})
        last_key = "lastBuiltAt" if section == "build" else "lastRenderedAt"
        lines.append(f"[ {section.upper()} ]")
        lines.append(f"  count    : {s.get('count', 0)}")
        lines.append(f"  avg      : {ms_str(s.get('avgMs'))} ms")
        lines.append(f"  max      : {ms_str(s.get('maxMs'))} ms")
        lines.append(f"  last     : {ms_str(s.get('lastMs'))} ms")
        lines.append(f"  errors   : {s.get('errorCount', 0)}")
        lines.append(f"  lastAt   : {ts_str(s.get(last_key))}")
        lines.append("")
    diag = data.get("diag", {})
    lines.append("[ DIAG ]")
    for ph in ("parse", "build", "render"):
        pd = diag.get(ph, {})
        lines.append(f"  {ph:6s}: warn={pd.get('warn', 0)}  error={pd.get('error', 0)}")
    return lines


def _format_events_lines(events: list) -> list:
    if not events:
        return ["(no events)"]
    lines = []
    for e in events:
        ts_ms = e.get("ts", 0)
        ts    = datetime.fromtimestamp(ts_ms / 1000).strftime("%H:%M:%S.%f")[:-3]
        phase = e.get("phase", "?")
        level = e.get("level", "?")
        lbl   = e.get("label", "")
        src   = e.get("source", "")
        msg   = e.get("message", "")
        pos   = e.get("position") or {}
        pos_s = (f"  @ {pos['systemID']}:{pos.get('line', '-')}"
                 if pos.get("systemID") else "")
        lines.append(f"[{ts}] [{phase}/{level}] {lbl}")
        if src:
            lines.append(f"  source  : {src}")
        lines.append(f"  message : {msg}{pos_s}")
        if e.get("sample"):
            lines.append(f"  sample  : {e['sample']}")
        if e.get("scriptText"):
            lines.append(f"  script  : {e['scriptText']}")
        lines.append("")
    return lines


