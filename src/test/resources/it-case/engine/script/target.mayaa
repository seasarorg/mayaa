<?xml version="1.0" encoding="ISO-8859-1"?>
<m:mayaa xmlns:m="http://mayaa.seasar.org"
	xmlns:c="http://java.sun.com/jstl/core_rt">

    <m:beforeRender><![CDATA[
        if (true) {
            page.script4 = 'script4Value';
            // } not close
        }
        var numberKeys = Packages.org.seasar.mayaa.test.util.TestObjectFactory.createNumberKeys();
        var numberMap = Packages.org.seasar.mayaa.test.util.TestObjectFactory.createNumberKeyMap();

        // "new java.lang.Integer(5) + 1" ï¿½Æï¿½ï¿½ï¿½ï¿½Xï¿½Nï¿½ï¿½ï¿½vï¿½gï¿½ï¿½Rhinoï¿½Ìï¿½ï¿½_ï¿½ï¿½"51"ï¿½ÉÈï¿½
        page.setAttribute('five', new java.lang.Integer(5));
        var six = five + 1;

        page.setAttribute('two', new java.lang.Integer(2));
        var seven = five + two;

        request.eight = 1;
        eight = 8;// rev.3380 (1.1.21) ï¿½ÅÌCï¿½ï¿½ï¿½ï¿½ï¿½ï¿½ï¿½ì·ï¿½é±ï¿½Æï¿½ï¿½mï¿½Fï¿½B
    ]]></m:beforeRender>

        <!--
            numberList1:
            - m:for + numberKeys.get(i) ã§ Java å´ã® Number ãé½åº¦åãåºãçµè·¯ã
            - key ã¯ List<Number> ã«å¥ã£ã¦ããå®ãªãã¸ã§ã¯ãï¼Byte/Short/Integer/Long/Float/Double/BigInteger/BigDecimalï¼
                ããã®ã¾ã¾æ¸¡ãããåæã®ç¢ºèªã±ã¼ã¹ã
            - ãã®ãã numberMap.get(key) ã¯ map å´ã®ã­ã¼åã¨ä¸è´ããå¨è¦ç´ ãåå¾ã§ããã
        -->
        <m:echo m:id="numberList1">
		<m:exec script="${ var listName = 'numberList1'; }" />
        <m:for init="${ var i = 0 }" test="${ i &lt; numberKeys.size() }" after="${ i++ }">${var key = numberKeys.get(i);}<m:doBody /></m:for>
    </m:echo>


        <!--
            numberList2:
            - m:forEach(items=numberKeys, var=key) ã®çµè·¯ã
            - var ã¸æ¸¡ã key ã¯ JS å´ã®å¤å¤æãçµç±ãããããRhino ãã¼ã¸ã§ã³å·®ã®å½±é¿ãåããããã
            - æ§æ¥ã¯ã10.2(Double) ã ãä¸è´ããã¦ããããRhino 1.9.1 ã§ã¯ 20(BigInteger) ãä¸è´ããã
            - ä¸æ¹ã§ 20.1(BigDecimal) ã¯å¼ãç¶ãä¸ä¸è´ã®ããåå¾ã§ããªãï¼ç©ºæå­ã«ãªãï¼ã
        -->
        <m:echo m:id="numberList2">
		<m:exec script="${ var listName = 'numberList2'; }" />
        <m:forEach items="${ numberKeys }" var="key" index="i"><m:doBody /></m:forEach>
    </m:echo>

    <m:echo m:id="numberKey">
        <m:attribute name="id" value="${ listName }${ id }${ i }" />
        <c:out value="${ key }" />
    </m:echo>
    <m:echo m:id="numberValue">
        <m:attribute name="id" value="${ listName }${ id }${ i }" />
        <!--
        numberMap.get(key) ã¯ key ã®å®åä¸è´ãå¿è¦ã
        æ¬ãã¡ã¤ã«ã§ã¯ numberList1 ã¨ numberList2 ã§ key ã®çµè·¯ãç°ãªãããã
        ã©ã®ã­ã¼ãä¸è´ãããï¼= å¤ãåå¾ã§ãããï¼ã«å·®ãåºããã¨ãç¢ºèªãã¦ããã

        itemsï¿½ÅZï¿½bï¿½gï¿½ï¿½ï¿½ï¿½ï¿½numberï¿½ÉÈï¿½ï¿½Äï¿½ï¿½Üï¿½ï¿½Ìï¿½Mapï¿½ÌLï¿½[ï¿½ÉÍgï¿½ï¿½ï¿½Èï¿½
        <c:out value="${ numberMap }" />/
        <c:out value="${ key }" />/
        <c:out value="${ typeof(key) }" />/
        -->
        <c:out value="${ numberMap.get(key) }" />
    </m:echo>

</m:mayaa>
