def _s(stdscr, row: int, col_: int, text: str, attr: int = 0) -> None:
    """Safe curses addstr — silently ignores boundary writes."""
    try:
        stdscr.addstr(row, col_, text, attr)
    except Exception:
        pass


class TUI:
    """Full-screen interactive spec list with keyboard navigation and detail overlays."""

    _HINTS_MAIN = (" ↑↓/j/k:move  PgUp/PgDn:page  Home/End"
                   "  p:proc-dump  s:spec  e:errors  w:warnings  r:refresh  q:quit")
    _HINTS_OVER = " ↑↓/j/k:scroll  PgUp/PgDn:page  Home/End  q/Esc:close"

    def __init__(self, base_url: str, interval: float = 3.0) -> None:
        self.base_url   = base_url
        self.interval   = interval
        self.specs      : list  = []
        self.aggregate  : dict  = {}
        self.cursor     : int   = 0
        self.scroll_top : int   = 0
        self.status     : str   = "initializing..."
        self.last_fetch : float = 0.0

    # ── data ────────────────────────────────────────────────────────

    def _fetch(self) -> None:
        try:
            data           = fetch(self.base_url, "/summary")
            self.specs     = sorted(
                data.get("specifications", []),
                key=lambda s: float(s.get("render", {}).get("avgMs") or 0),
                reverse=True,
            )
            self.aggregate = data.get("aggregate", {})
            self.status    = f"updated {now_str()}"
        except Exception as exc:
            self.status = f"error: {exc}"
        self.last_fetch = time.time()

    # ── main loop ───────────────────────────────────────────────────

    def run(self, stdscr) -> None:
        import curses as _c
        _c.curs_set(0)
        _c.start_color()
        _c.use_default_colors()
        _c.init_pair(1, _c.COLOR_WHITE,  _c.COLOR_BLUE)   # title / overlay header
        _c.init_pair(3, _c.COLOR_RED,    -1)              # error row
        _c.init_pair(4, _c.COLOR_YELLOW, -1)              # warn row
        _c.init_pair(5, _c.COLOR_CYAN,   -1)              # footer hints
        self._fetch()

        while True:
            if time.time() - self.last_fetch >= self.interval:
                self._fetch()

            h, w = stdscr.getmaxyx()
            self._draw_main(stdscr, h, w)
            stdscr.timeout(200)
            key = stdscr.getch()
            if key == -1:
                continue

            n = len(self.specs)
            if n:
                self.cursor = max(0, min(self.cursor, n - 1))

            if key in (ord('q'), 27):                              # q / Esc
                break
            elif key in (_c.KEY_UP,   ord('k')) and n:
                self.cursor = max(0, self.cursor - 1)
            elif key in (_c.KEY_DOWN, ord('j')) and n:
                self.cursor = min(n - 1, self.cursor + 1)
            elif key == _c.KEY_PPAGE and n:
                hh, _ = stdscr.getmaxyx()
                self.cursor = max(0, self.cursor - max(1, hh - 7))
            elif key == _c.KEY_NPAGE and n:
                hh, _ = stdscr.getmaxyx()
                self.cursor = min(n - 1, self.cursor + max(1, hh - 7))
            elif key == _c.KEY_HOME:
                self.cursor = 0
            elif key == _c.KEY_END:
                self.cursor = max(0, n - 1)
            elif key == ord('r'):
                self._fetch()
            elif key in (ord('p'), ord('d')) and n:
                self._open_proc_dump(stdscr, self.specs[self.cursor])
            elif key in (ord('s'), ord('i'), 10, 13) and n:       # s / i / Enter
                self._open_spec_detail(stdscr, self.specs[self.cursor])
            elif key == ord('e') and n:
                self._open_events(stdscr, self.specs[self.cursor], "errors")
            elif key == ord('w') and n:
                self._open_events(stdscr, self.specs[self.cursor], "warnings")

    # ── draw main screen ────────────────────────────────────────────

    def _draw_main(self, stdscr, h: int, w: int) -> None:
        import curses as _c
        stdscr.erase()
        n      = len(self.specs)
        list_h = max(1, h - 6)          # body rows available for the spec list

        if n:
            self.cursor = max(0, min(self.cursor, n - 1))
        if self.cursor < self.scroll_top:
            self.scroll_top = self.cursor
        elif self.cursor >= self.scroll_top + list_h:
            self.scroll_top = self.cursor - list_h + 1

        # row 0 — title bar (full width, colour_pair 1)
        title = f" MAYAA PROFILE  {now_str()}  {self.base_url}  [{self.status}]"
        _s(stdscr, 0, 0, title.ljust(w)[:w], _c.color_pair(1) | _c.A_BOLD)

        # row 1 — aggregate stats
        agg = self.aggregate
        agg_line = (
            f" tracked:{agg.get('trackedCount', 0)}  "
            f"build:{agg.get('totalBuildCount', 0)}"
            f"(err:{agg.get('totalBuildErrorCount', 0)})  "
            f"render:{agg.get('totalRenderCount', 0)}"
            f"(err:{agg.get('totalRenderErrorCount', 0)})  "
            f"warn:{agg.get('totalDiagWarnCount', 0)}  "
            f"error:{agg.get('totalDiagErrorCount', 0)}"
        )
        _s(stdscr, 1, 0, agg_line[:w-1])

        # row 2 — separator
        _s(stdscr, 2, 0, ("─" * w)[:w-1])

        # row 3 — column header
        _s(stdscr, 3, 0, ("  " + _spec_header_plain())[:w-1], _c.A_REVERSE)

        # rows 4… — spec rows
        for idx in range(self.scroll_top, min(self.scroll_top + list_h, n)):
            spec  = self.specs[idx]
            diag  = spec.get("diag", {})
            de_c  = sum(diag.get(p, {}).get("error", 0) for p in ("parse", "build", "render"))
            dw_c  = sum(diag.get(p, {}).get("warn",  0) for p in ("parse", "build", "render"))
            mark  = ">" if idx == self.cursor else " "
            row_t = mark + " " + _spec_row_plain(spec)
            if idx == self.cursor:
                attr = _c.A_REVERSE
            elif de_c > 0:
                attr = _c.color_pair(3)
            elif dw_c > 0:
                attr = _c.color_pair(4)
            else:
                attr = 0
            _s(stdscr, 4 + idx - self.scroll_top, 0, row_t[:w-1], attr)

        # scroll bar (rightmost column)
        if n > list_h:
            ratio   = list_h / n
            bar_top = int(self.scroll_top * ratio)
            bar_len = max(1, int(list_h * ratio))
            for r in range(list_h):
                ch = "\u2588" if bar_top <= r < bar_top + bar_len else "\u2591"
                try:
                    stdscr.addstr(4 + r, w - 1, ch)
                except _c.error:
                    pass

        # footer
        _s(stdscr, h - 2, 0, ("─" * w)[:w-1])
        _s(stdscr, h - 1, 0, self._HINTS_MAIN[:w-1], _c.color_pair(5))
        stdscr.refresh()

    # ── overlay viewer ──────────────────────────────────────────────

    def _show_overlay(self, stdscr, title: str, lines: list) -> None:
        import curses as _c
        scroll = 0
        _c.curs_set(0)
        while True:
            h, w    = stdscr.getmaxyx()
            visible = max(1, h - 3)
            total   = len(lines)
            stdscr.erase()

            # title bar
            _s(stdscr, 0, 0, f" {title}".ljust(w)[:w], _c.color_pair(1) | _c.A_BOLD)

            # content
            for i, line in enumerate(lines[scroll:scroll + visible]):
                _s(stdscr, i + 1, 0, line[:w-1])

            # footer
            pct  = f"[{scroll+1}-{min(scroll+visible, max(1,total))}/{max(1,total)}]"
            foot = f"{self._HINTS_OVER}  {pct}"
            _s(stdscr, h - 2, 0, ("─" * w)[:w-1])
            _s(stdscr, h - 1, 0, foot[:w-1], _c.color_pair(5))
            stdscr.refresh()

            stdscr.timeout(-1)
            key        = stdscr.getch()
            max_scroll = max(0, total - visible)
            if key in (ord('q'), 27):
                break
            elif key in (_c.KEY_UP,   ord('k')):
                scroll = max(0, scroll - 1)
            elif key in (_c.KEY_DOWN, ord('j')):
                scroll = min(max_scroll, scroll + 1)
            elif key == _c.KEY_PPAGE:
                scroll = max(0, scroll - visible)
            elif key == _c.KEY_NPAGE:
                scroll = min(max_scroll, scroll + visible)
            elif key == _c.KEY_HOME:
                scroll = 0
            elif key == _c.KEY_END:
                scroll = max_scroll

    # ── detail openers ──────────────────────────────────────────────

    def _open_proc_dump(self, stdscr, spec: dict) -> None:
        sid = spec.get("systemID", "")
        url = _profile_url(
            self.base_url,
            f"/proc-dump?id={urllib.parse.quote(sid, safe='')}&format=text",
        )
        try:
            with urllib.request.urlopen(url, timeout=15) as resp:
                lines = resp.read().decode("utf-8").splitlines()
        except Exception as exc:
            lines = [f"Error: {exc}"]
        self._show_overlay(stdscr, f"PROC DUMP  {sid}", lines)

    def _open_spec_detail(self, stdscr, spec: dict) -> None:
        sid = spec.get("systemID", "")
        url = _profile_url(self.base_url, f"/spec?id={urllib.parse.quote(sid, safe='')}")
        try:
            with urllib.request.urlopen(url, timeout=10) as resp:
                data  = json.loads(resp.read().decode("utf-8"))
            lines = _format_spec_detail_lines(data)
        except Exception as exc:
            lines = [f"Error: {exc}"]
        self._show_overlay(stdscr, f"SPEC DETAIL  {sid}", lines)

    def _open_events(self, stdscr, spec: dict, kind: str) -> None:
        sid = spec.get("systemID", "")
        url = _profile_url(self.base_url, f"/list-{kind}?since=0")
        try:
            with urllib.request.urlopen(url, timeout=10) as resp:
                data       = json.loads(resp.read().decode("utf-8"))
            all_events  = data.get("events", [])
            spec_events = [
                e for e in all_events
                if (e.get("position") or {}).get("systemID") == sid
            ]
            extra = ""
            if not spec_events:
                spec_events = all_events
                extra       = "  [no position match — showing all]"
            header = f"total:{len(all_events)}  this-spec:{len(spec_events)}{extra}"
            lines  = [header, ""] + _format_events_lines(spec_events)
        except Exception as exc:
            lines = [f"Error: {exc}"]
        self._show_overlay(stdscr, f"{kind.upper()}  {sid}", lines)


def cmd_tui(args) -> None:
    """Launch interactive full-screen TUI."""
    import curses as _c
    tui = TUI(base_url=args.url, interval=getattr(args, "interval", 3.0))
    try:
        _c.wrapper(tui.run)
    except KeyboardInterrupt:
        pass


# ──────────────────────────────────────────────────────────────────
# argparse
# ──────────────────────────────────────────────────────────────────

def _common(sub, with_json: bool = True, with_n: bool = False) -> argparse.ArgumentParser:
    """Add common flags to a subparser."""
    if with_json:
        sub.add_argument("--json", action="store_true",
                         help="Output raw JSON (for AI tool use / piping)")
    if with_n:
        sub.add_argument("--n", type=int, default=10, metavar="N",
                         help="Number of results (default: 10)")
    return sub


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="mayaa-profile",
        description="Mayaa SpecificationProfile API CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument(
        "--url", default="http://localhost:8080", metavar="URL",
        help="Base URL of the Mayaa app (default: http://localhost:8080)",
    )
    parser.add_argument("--version", action="version", version=f"%(prog)s {__version__}")

    sub = parser.add_subparsers(dest="command", metavar="COMMAND")

    # tui  (default command — interactive full-screen viewer)
    p = sub.add_parser("tui", help="Interactive full-screen TUI (default)")
    p.add_argument("--interval", "-i", type=float, default=3.0, metavar="SEC",
                   help="Auto-refresh interval in seconds (default: 3)")

    # top
    p = sub.add_parser("top", help="Real-time top-like display")
    p.add_argument("--n", type=int, default=10, metavar="N",
                   help="Number of specs to display (default: 10)")
    p.add_argument("--interval", "-i", type=float, default=3.0, metavar="SEC",
                   help="Refresh interval in seconds (default: 3)")

    # summary
    _common(sub.add_parser("summary", help="One-shot aggregate + spec list"))

    # slow
    _common(sub.add_parser("slow", help="Top N specs by avg render time"), with_n=True)

    # diag
    _common(sub.add_parser("diag", help="Top N specs by diagnostic event count"), with_n=True)

    # spec
    p = sub.add_parser("spec", help="Detail for a single specification")
    p.add_argument("id", help="systemID, e.g. /index.html")
    _common(p)

    # errors
    p = sub.add_parser("errors", help="ERROR events from DiagnosticEventBuffer")
    p.add_argument("--since", type=int, default=None, metavar="TS",
                   help="Only events after this epoch-millis (0 = all, default: 0)")
    p.add_argument("--follow", "-f", action="store_true",
                   help="Poll continuously (like tail -f)")
    p.add_argument("--interval", "-i", type=float, default=2.0, metavar="SEC",
                   help="Polling interval for --follow (default: 2)")
    _common(p)

    # warnings
    p = sub.add_parser("warnings", help="WARN events from DiagnosticEventBuffer")
    p.add_argument("--since", type=int, default=None, metavar="TS")
    p.add_argument("--follow", "-f", action="store_true")
    p.add_argument("--interval", "-i", type=float, default=2.0, metavar="SEC")
    _common(p)

    # dump — always JSON, no --json flag needed
    p = sub.add_parser("dump",
                       help="Dump all data as a single JSON object (AI analysis)")
    p.add_argument("--n", type=int, default=20, metavar="N",
                   help="top-N for slow/diag (default: 20)")

    # proc-dump
    p = sub.add_parser("proc-dump",
                       help="Dump ProcessorTree/NodeTree for a cached specification")
    p.add_argument("id", help="systemID, e.g. /index.html")
    p.add_argument("--contents", action="store_true",
                   help="Include literal text content (default: omit)")
    _common(p)

    # reset
    p = sub.add_parser("reset", help="Reset profiling counters")
    p.add_argument("--id", default=None, metavar="SYSTEM_ID",
                   help="Reset a single spec (omit to reset all)")
    _common(p)

    return parser


def main() -> None:
    parser = build_parser()
    args   = parser.parse_args()

    # Default --json=False for commands that don't define it
    if not hasattr(args, "json"):
        args.json = False

    command = args.command
    if command is None or command == "tui":
        if not hasattr(args, "interval"):
            args.interval = 3.0
        cmd_tui(args)
    elif command == "top":
        if not hasattr(args, "n"):
            args.n = 10
        if not hasattr(args, "interval"):
            args.interval = 3.0
        cmd_top(args)
    elif command == "summary":
        cmd_summary(args)
    elif command == "slow":
        cmd_slow(args)
    elif command == "diag":
        cmd_diag(args)
    elif command == "spec":
        cmd_spec(args)
    elif command == "errors":
        cmd_events(args, "errors")
    elif command == "warnings":
        cmd_events(args, "warnings")
    elif command == "dump":
        cmd_dump(args)
    elif command == "proc-dump":
        cmd_proc_dump(args)
    elif command == "reset":
        cmd_reset(args)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
