def cmd_spec(args) -> None:
    sid = urllib.parse.quote(args.id, safe="")
    data = fetch(args.url, f"/spec?id={sid}")
    if args.json:
        print(json.dumps(data, ensure_ascii=False, indent=2))
        return
    print(f"{_c(BOLD, 'SPEC')}  {_c(CYAN, data.get('systemID', ''))}  "
          f"[{data.get('type', '')}]")
    print()
    for section in ("build", "render"):
        s = data.get(section, {})
        last_key = "lastBuiltAt" if section == "build" else "lastRenderedAt"
        print(f"  {_c(BOLD, section.upper())}")
        print(f"    count={s.get('count', 0)}"
              f"  avg={ms_str(s.get('avgMs'))} ms"
              f"  max={ms_str(s.get('maxMs'))} ms"
              f"  last={ms_str(s.get('lastMs'))} ms"
              f"  err={s.get('errorCount', 0)}"
              f"  lastAt={ts_str(s.get(last_key))}")
    print()
    diag = data.get("diag", {})
    print(f"  {_c(BOLD, 'DIAG')}")
    for ph in ("parse", "build", "render"):
        pd = diag.get(ph, {})
        print(f"    {ph}: warn={pd.get('warn', 0)}  error={pd.get('error', 0)}")


def cmd_events(args, kind: str) -> None:
    """kind: 'errors' or 'warnings'"""
    path = f"/list-{kind}"

    if not args.follow:
        since = args.since if args.since is not None else 0
        data  = fetch(args.url, f"{path}?since={since}")
        _print_events_result(data, f"{kind.upper()}", args.json)
        return

    # follow / tail -f mode
    since = args.since if args.since is not None else 0
    print(f"Following {kind} from {args.url}{path}  (Ctrl+C to stop)\n")
    try:
        while True:
            data   = fetch(args.url, f"{path}?since={since}")
            events = data.get("events", [])
            if events:
                for e in events:
                    _print_event(e)
                since = data.get("nextSince", since)
            time.sleep(args.interval)
    except KeyboardInterrupt:
        print("\nStopped.")


def cmd_dump(args) -> None:
    """Comprehensive JSON dump — designed for AI tool consumption."""
    now_ms   = int(time.time() * 1000)
    summary  = fetch(args.url, "/summary")
    top_slow = fetch(args.url, f"/top-slow?n={args.n}")
    top_diag = fetch(args.url, f"/top-diag?n={args.n}")
    errors   = fetch(args.url, "/list-errors")
    warnings = fetch(args.url, "/list-warnings")

    dump = {
        "meta": {
            "tool": "mayaa-profile",
            "version": __version__,
            "url": args.url,
            "timestamp": now_str(),
            "timestampMillis": now_ms,
            "description": (
                "Snapshot of Mayaa SpecificationProfile data. "
                "Use top_slow/top_diag to identify hot specs. "
                "Use recent_errors/recent_warnings for diagnostic events. "
                "Pass nextSince from events response as ?since= to fetch incremental updates."
            ),
            "endpoints": {
                "summary":       f"{args.url}/mayaa-admin/profile/summary",
                "top_slow":      f"{args.url}/mayaa-admin/profile/top-slow?n={args.n}",
                "top_diag":      f"{args.url}/mayaa-admin/profile/top-diag?n={args.n}",
                "list_errors":   f"{args.url}/mayaa-admin/profile/list-errors",
                "list_warnings": f"{args.url}/mayaa-admin/profile/list-warnings",
                "spec":          f"{args.url}/mayaa-admin/profile/spec?id=SYSTEM_ID",
                "reset_all":     f"POST {args.url}/mayaa-admin/profile/reset",
                "reset_spec":    f"POST {args.url}/mayaa-admin/profile/reset?id=SYSTEM_ID",
            },
        },
        "summary":          summary,
        "top_slow":         top_slow,
        "top_diag":         top_diag,
        "recent_errors":    errors,
        "recent_warnings":  warnings,
    }
    print(json.dumps(dump, ensure_ascii=False, indent=2))


def cmd_reset(args) -> None:
    path = "/reset"
    if args.id:
        path += "?" + urllib.parse.urlencode({"id": args.id})
    result = post(args.url, path)
    if args.json:
        print(json.dumps(result, ensure_ascii=False, indent=2))
    else:
        if result.get("reset") == "all":
            print("Reset: all counters cleared.")
        else:
            print(f"Reset: {result.get('id', '')} cleared.")


def cmd_proc_dump(args) -> None:
    sid = urllib.parse.quote(args.id, safe="")
    contents_param = "true" if args.contents else "false"

    if args.json:
        # JSON ツリー構造 — AI ツール返却向け
        url = _profile_url(args.url, f"/proc-dump?id={sid}&format=json&contents={contents_param}")
        try:
            with urllib.request.urlopen(url, timeout=15) as resp:
                data = json.loads(resp.read().decode("utf-8"))
            print(json.dumps(data, ensure_ascii=False, indent=2))
        except urllib.error.HTTPError as e:
            sys.exit(f"HTTP {e.code} {e.reason}: {url}")
        except urllib.error.URLError as e:
            sys.exit(f"Connection error: {e.reason}")
        return

    # テキスト形式 (ANSI 色付き)
    url = _profile_url(args.url, f"/proc-dump?id={sid}&format=text&contents={contents_param}")
    try:
        with urllib.request.urlopen(url, timeout=15) as resp:
            text = resp.read().decode("utf-8")
    except urllib.error.HTTPError as e:
        sys.exit(f"HTTP {e.code} {e.reason}: {url}")
    except urllib.error.URLError as e:
        sys.exit(f"Connection error: {e.reason}")

    for line in text.splitlines():
        # セクションヘッダをボールド、ノード行にはインデントに応じた色付け
        if line.startswith("SYSTEM-ID:") or line.startswith("TYPE:"):
            print(_c(BOLD, line))
        elif "-----" in line:
            print(_c(CYAN, line))
        elif "LiteralCharacters" in line:
            print(_c(DIM, line))
        elif "Directive" in line:
            print(_c(YELLOW, line))
        else:
            # インデント深さに応じてグラデーション
            depth = len(line) - len(line.lstrip())
            if depth == 0:
                print(line)
            elif depth <= 4:
                print(_c(GREEN, line))
            else:
                print(line)



