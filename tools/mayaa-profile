#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
mayaa-profile — Mayaa SpecificationProfile API CLI

SYNOPSIS
    mayaa-profile [--url URL] COMMAND [OPTIONS]

COMMANDS (human-readable, ANSI-colored)
    top        Real-time top-like display (refreshes periodically)
    summary    One-shot aggregate + spec table
    slow       Top N specs by avg render time
    diag       Top N specs by diagnostic event count
    spec ID    Detail view for a single specification
    errors     Recent ERROR events  (supports --since, --follow)
    warnings   Recent WARN events   (supports --since, --follow)

COMMANDS (machine-readable JSON — for AI tool calls)
    dump       Dump all data as a single JSON object
    slow   --json  / diag --json / summary --json / spec ID --json
    errors --json  / warnings --json [--since TS]

MANAGEMENT
    reset           Reset all profiling counters
    reset --id ID   Reset a single specification's counters
"""

import argparse
import json
import os
import shutil
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from datetime import datetime

__version__ = "0.1.0"


# ──────────────────────────────────────────────────────────────────
# HTTP helpers
# ──────────────────────────────────────────────────────────────────

def _profile_url(base: str, path: str) -> str:
    return base.rstrip("/") + "/mayaa-admin/profile" + path


def fetch(base: str, path: str) -> object:
    url = _profile_url(base, path)
    try:
        with urllib.request.urlopen(url, timeout=10) as resp:
            return json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        sys.exit(f"HTTP {e.code} {e.reason}: {url}")
    except urllib.error.URLError as e:
        sys.exit(f"Connection error ({url}): {e.reason}")
    except json.JSONDecodeError as e:
        sys.exit(f"Invalid JSON from {url}: {e}")


def post(base: str, path: str) -> object:
    url = _profile_url(base, path)
    req = urllib.request.Request(url, method="POST", data=b"")
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        sys.exit(f"HTTP {e.code} {e.reason}: {url}")
    except urllib.error.URLError as e:
        sys.exit(f"Connection error ({url}): {e.reason}")


# ──────────────────────────────────────────────────────────────────
# Terminal / ANSI helpers
# ──────────────────────────────────────────────────────────────────

def _ansi() -> bool:
    return sys.stdout.isatty() and os.environ.get("NO_COLOR") is None


def _c(codes: str, text: str) -> str:
    return (codes + text + "\033[0m") if _ansi() else text


BOLD    = "\033[1m"
DIM     = "\033[2m"
RED     = "\033[31m"
YELLOW  = "\033[33m"
CYAN    = "\033[36m"
GREEN   = "\033[32m"
REVERSE = "\033[7m"

CLEAR_HOME = "\033[H\033[J"  # cursor home + clear to end (less flicker than \033[2J)


def term_width() -> int:
    try:
        return shutil.get_terminal_size().columns
    except Exception:
        return 80


# ──────────────────────────────────────────────────────────────────
# Formatting helpers
# ──────────────────────────────────────────────────────────────────

def ms_str(ms) -> str:
    if ms is None:
        return "-"
    ms = float(ms)
    if ms < 1000:
        return f"{ms:.0f}"
    return f"{ms/1000:.1f}s"


def ts_str(ts_millis) -> str:
    if not ts_millis:
        return "-"
    return datetime.fromtimestamp(ts_millis / 1000).strftime("%H:%M:%S")


def now_str() -> str:
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")


def col(s, width: int, align: str = "left") -> str:
    s = str(s) if s is not None else ""
    if align == "right":
        return s.rjust(width)[:width]
    return s.ljust(width)[:width]


# ──────────────────────────────────────────────────────────────────
# Spec table
# ──────────────────────────────────────────────────────────────────

# Column widths: TYPE, SYSTEMID, B-cnt, B-avg, B-max, R-cnt, R-avg, R-max, W, E
_W = [8, 34, 5, 6, 6, 5, 6, 6, 3, 3]


def _spec_header() -> str:
    h = (
        col("TYPE",   _W[0]) + "  " +
        col("SYSTEM-ID", _W[1]) + "  " +
        col("B-CNT", _W[2], "right") + "  " +
        col("AVG",   _W[3], "right") + " " +
        col("MAX",   _W[4], "right") + " ms  " +
        col("R-CNT", _W[5], "right") + "  " +
        col("AVG",   _W[6], "right") + " " +
        col("MAX",   _W[7], "right") + " ms  " +
        col("W",     _W[8], "right") + " " +
        col("E",     _W[9], "right")
    )
    return _c(BOLD + REVERSE, h) if _ansi() else h


def _spec_row(spec: dict) -> str:
    sid   = spec.get("systemID", "")
    typ   = spec.get("type", "")
    build = spec.get("build", {})
    rend  = spec.get("render", {})
    diag  = spec.get("diag", {})

    dw = sum(diag.get(p, {}).get("warn",  0) for p in ("parse", "build", "render"))
    de = sum(diag.get(p, {}).get("error", 0) for p in ("parse", "build", "render"))
    be = build.get("errorCount", 0)
    re = rend.get("errorCount", 0)

    row = (
        col(typ, _W[0]) + "  " +
        col(sid, _W[1]) + "  " +
        col(build.get("count", 0),         _W[2], "right") + "  " +
        col(ms_str(build.get("avgMs")),    _W[3], "right") + " " +
        col(ms_str(build.get("maxMs")),    _W[4], "right") + "     " +
        col(rend.get("count", 0),          _W[5], "right") + "  " +
        col(ms_str(rend.get("avgMs")),     _W[6], "right") + " " +
        col(ms_str(rend.get("maxMs")),     _W[7], "right") + "     " +
        col(dw,                            _W[8], "right") + " " +
        col(de,                            _W[9], "right")
    )
    if de > 0 or re > 0 or be > 0:
        row = _c(RED, row)
    elif dw > 0:
        row = _c(YELLOW, row)
    return row


def _print_spec_table(specs: list) -> None:
    print("  " + _spec_header())
    for spec in specs:
        print("  " + _spec_row(spec))


# ──────────────────────────────────────────────────────────────────
# Event formatter
# ──────────────────────────────────────────────────────────────────

def _print_event(e: dict) -> None:
    ts_ms = e.get("ts", 0)
    ts    = datetime.fromtimestamp(ts_ms / 1000).strftime("%H:%M:%S.%f")[:-3]
    phase = e.get("phase", "?")
    level = e.get("level", "?")
    lbl   = e.get("label", "")
    src   = e.get("source", "")
    msg   = e.get("message", "")
    pos   = e.get("position")

    color = RED if level == "ERROR" else YELLOW
    pos_s = ""
    if pos and pos.get("systemID"):
        pos_s = f"  @ {pos['systemID']}:{pos.get('line', '-')}"

    print(
        "  " +
        _c(BOLD, ts) + "  " +
        _c(color, f"[{phase}/{level}]") + "  " +
        (_c(CYAN, lbl) + "  " if lbl else "") +
        (src + "  " if src else "") +
        msg +
        pos_s
    )
    if e.get("sample"):
        print(f"      sample: {e['sample']}")
    if e.get("scriptText"):
        print(f"      script: {e['scriptText']}")


def _print_events_result(data: dict, label: str, as_json: bool) -> None:
    if as_json:
        print(json.dumps(data, ensure_ascii=False, indent=2))
        return
    count = data.get("count", 0)
    next_since = data.get("nextSince", 0)
    events = data.get("events", [])
    print(f"{_c(BOLD, label)}  count={count}  nextSince={next_since}")
    if not events:
        print("  (no events)")
        return
    print()
    for e in events:
        _print_event(e)


