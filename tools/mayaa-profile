def cmd_top(args) -> None:
    try:
        while True:
            data  = fetch(args.url, "/summary")
            agg   = data.get("aggregate", {})
            specs = sorted(
                data.get("specifications", []),
                key=lambda s: float(s.get("render", {}).get("avgMs") or 0),
                reverse=True,
            )[:args.n]

            if _ansi():
                print(CLEAR_HOME, end="")

            w = term_width()
            # ── header ──────────────────────────────────────────
            print(_c(BOLD, "MAYAA PROFILE") +
                  f"  {now_str()}  {_c(CYAN, args.url)}"
                  f"  (top={args.n}, interval={args.interval}s)")
            print(_c(DIM, "─" * min(w, 100)))

            # ── aggregate ───────────────────────────────────────
            tb  = agg.get("totalBuildCount",       0)
            ebe = agg.get("totalBuildErrorCount",  0)
            tr  = agg.get("totalRenderCount",      0)
            ere = agg.get("totalRenderErrorCount", 0)
            dw  = agg.get("totalDiagWarnCount",    0)
            de  = agg.get("totalDiagErrorCount",   0)
            print(
                f"  tracked: {_c(BOLD, str(agg.get('trackedCount', 0)))}  "
                f"build: {tb}({_c(RED, str(ebe))} err)  "
                f"render: {tr}({_c(RED, str(ere))} err)  "
                f"diag warn: {_c(YELLOW, str(dw))}  "
                f"diag error: {_c(RED, str(de))}"
            )
            print()

            # ── spec table ──────────────────────────────────────
            sub_hdr = "── slowest by avg render (ms) ──"
            print(f"  {_c(BOLD, sub_hdr)}")
            print()
            _print_spec_table(specs)
            print()
            print(f"  {_c(DIM, 'columns: BUILD(cnt avg max)  RENDER(cnt avg max)  DIAG(W E)')}")
            print()
            print(f"  {_c(CYAN, 'Ctrl+C')} to quit  |  refreshing in {args.interval}s ...")

            time.sleep(args.interval)

    except KeyboardInterrupt:
        print("\nExiting.")


def cmd_summary(args) -> None:
    data  = fetch(args.url, "/summary")
    if args.json:
        print(json.dumps(data, ensure_ascii=False, indent=2))
        return
    agg   = data.get("aggregate", {})
    specs = sorted(
        data.get("specifications", []),
        key=lambda s: float(s.get("render", {}).get("avgMs") or 0),
        reverse=True,
    )
    print(f"{_c(BOLD, 'MAYAA PROFILE SUMMARY')}  {now_str()}  {args.url}")
    print()
    print(f"  tracked={agg.get('trackedCount', 0)}"
          f"  build={agg.get('totalBuildCount', 0)}(err={agg.get('totalBuildErrorCount', 0)})"
          f"  render={agg.get('totalRenderCount', 0)}(err={agg.get('totalRenderErrorCount', 0)})"
          f"  diagWarn={agg.get('totalDiagWarnCount', 0)}"
          f"  diagError={agg.get('totalDiagErrorCount', 0)}")
    print()
    _print_spec_table(specs)


def cmd_slow(args) -> None:
    data = fetch(args.url, f"/top-slow?n={args.n}")
    if args.json:
        print(json.dumps(data, ensure_ascii=False, indent=2))
        return
    print(f"{_c(BOLD, f'TOP {args.n} SLOW RENDERS')}  {now_str()}")
    print()
    _print_spec_table(data)


def cmd_diag(args) -> None:
    data = fetch(args.url, f"/top-diag?n={args.n}")
    if args.json:
        print(json.dumps(data, ensure_ascii=False, indent=2))
        return
    print(f"{_c(BOLD, f'TOP {args.n} BY DIAG EVENTS')}  {now_str()}")
